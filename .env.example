# Public browser configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_MARKETING_URL=http://www.localhost:3000
NEXT_PUBLIC_PANEL_URL=http://panel.localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=hello@restaurantpos.com
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Server-only: e-posta dispatcher'ı (app/api/cron/email-dispatch)
# SUPABASE_SECRET_KEY: Supabase Dashboard > Settings > API > secret key (asla commit etme)
SUPABASE_SECRET_KEY=
# RESEND_API_KEY: https://resend.com — domain DKIM/SPF doğrulaması gerekir
RESEND_API_KEY=
EMAIL_FROM="RestaurantPOS <bildirim@ornekdomain.com>"
# Vercel Cron isteklerini doğrulamak için rastgele uzun bir değer
CRON_SECRET=
